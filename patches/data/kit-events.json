{
  "kit-party-add": {
    "frequency": "ALWAYS",
    "repeat": "ONCE",
    "condition": "plot.line >= 3500",
    "eventType": "CUTSCENE",
    "overrideSideMessage": false,
    "event": [
      {
        "type": "SET_CONTACT_TYPE",
        "member": "Kit",
        "status": "FRIEND"
      },
      {
        "withElse": true,
        "type": "IF",
        "condition": "player.level <= 75",
        "thenStep": [
          {
            "type": "SET_PARTY_MEMBER_LEVEL_VAR",
            "member": "Kit",
            "level": {
              "varName": "player.level"
            },
            "updateEquipment": true
          }
        ],
        "elseStep": [
          {
            "type": "SET_PARTY_MEMBER_LEVEL",
            "member": "Kit",
            "level": 75,
            "updateEquipment": true
          }
        ]
      },
      {
        "withElse": true,
        "type": "IF",
        "condition": "plot.line >= 44650",
        "thenStep": [
          {
            "type": "SET_PARTY_MEMBER_SP_LEVEL",
            "member": "Kit",
            "level": 4
          }
        ],
        "elseStep": [
          {
            "withElse": true,
            "type": "IF",
            "condition": "plot.line >= 18650",
            "thenStep": [
              {
                "type": "SET_PARTY_MEMBER_SP_LEVEL",
                "member": "Kit",
                "level": 3
              }
            ],
            "elseStep": [
              {
                "withElse": true,
                "type": "IF",
                "condition": "plot.line >= 6600",
                "thenStep": [
                  {
                    "type": "SET_PARTY_MEMBER_SP_LEVEL",
                    "member": "Kit",
                    "level": 2
                  }
                ],
                "elseStep": [
                  {
                    "type": "SET_PARTY_MEMBER_SP_LEVEL",
                    "member": "Kit",
                    "level": 1
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "SET_PARTY_MEMBER_ALL_ELEMENTS",
        "member": "Kit",
        "allElements": false
      },
      {
        "type": "SHOW_GET_MSG",
        "msgType": "PARTY",
        "object": {
          "en_US": "Kit"
        }
      }
    ],
    "type": {
      "type": "MAP_ENTERED"
    }
  },
