  "kit-contact": {
    "frequency": "ALWAYS",
    "repeat": "REPEAT",
    "eventType": "PARALLEL",
    "overrideSideMessage": false,
    "event": [
      {
        "outgoing": true,
        "type": "RING_PRIVATE_MSG"
      },
      {
        "type": "START_PRIVATE_MSG"
      },
      {
        "side": "RIGHT",
        "order": 1,
        "clearSide": false,
        "type": "ADD_MSG_PERSON",
        "person": {
          "person": "main.lea",
          "expression": "DEFAULT"
        }
      },
      {
        "withElse": false,
        "type": "IF",
        "condition": "party.has.Kit && !location.isMapDungeon",
        "thenStep": [
          {
            "message": {
              "en_US": "Hi?"
            },
            "autoContinue": false,
            "type": "SHOW_MSG",
            "person": {
              "person": "main.lea",
              "expression": "SURPRISED_TOWARD"
            }
          },
          {
            "side": "RIGHT",
            "order": 0,
            "clearSide": false,
            "type": "ADD_MSG_PERSON",
            "person": {
              "person": "guests.kit",
              "expression": "DEFAULT"
            }
          },
          {
            "message": {
              "en_US": "I'm right here, Lea! Why are you calling?"
            },
            "autoContinue": false,
            "type": "SHOW_MSG",
            "person": {
              "person": "guests.kit",
              "expression": "DEFAULT"
            }
          },
          {
            "message": {
              "en_US": "..!"
            },
            "autoContinue": false,
            "type": "SHOW_MSG",
            "person": {
              "person": "main.lea",
              "expression": "SHOCKED"
            }
          },
          {
            "type": "SET_MSG_EXPRESSION",
            "person": {
              "person": "main.lea",
              "expression": "SURPRISED_AWAY"
            }
          },
          {
            "message": {
              "en_US": "Unless I'm glitched out and you can't see me?"
            },
            "autoContinue": false,
            "type": "SHOW_MSG",
            "person": {
              "person": "guests.kit",
              "expression": "DEFAULT"
            }
          },
          {
            "person": "guests.kit",
            "type": "REMOVE_MSG_PERSON"
          },
          {
            "message": {
              "en_US": "..."
            },
            "autoContinue": false,
            "type": "SHOW_MSG",
            "person": {
              "person": "main.lea",
              "expression": "ANNOYED"
            }
          },
          {
            "name": "end",
            "type": "GOTO_LABEL"
          }
        ]
      },
      {
        "withElse": false,
        "type": "IF",
        "condition": "party.has.Kit && location.isMapDungeon",
        "thenStep": [
          {
            "side": "LEFT",
            "order": 0,
            "clearSide": false,
            "type": "ADD_MSG_PERSON",
            "person": {
              "person": "guests.kit",
              "expression": "DEFAULT"
            }
          },
          {
            "message": {
              "en_US": "This dungeon is quite foolproof! There aren't many \\c[3]JADC\\c[0] skips I can find..."
            },
            "autoContinue": false,
            "type": "SHOW_MSG",
            "person": {
              "person": "guests.kit",
              "expression": "DEFAULT"
            }
          },
          {
            "message": {
              "en_US": "..."
            },
            "autoContinue": false,
            "type": "SHOW_MSG",
            "person": {
              "person": "main.lea",
              "expression": "SMILE"
            }
          },
          {
            "name": "end",
            "type": "GOTO_LABEL"
          }
        ]
      },
      {
        "side": "LEFT",
        "order": 0,
        "clearSide": false,
        "type": "ADD_MSG_PERSON",
        "person": {
          "person": "guests.kit",
          "expression": "DEFAULT"
        }
      },
      {
        "message": {
          "en_US": "Hi!"
        },
        "autoContinue": false,
        "type": "SHOW_MSG",
        "person": {
          "person": "main.lea",
          "expression": "EXCITED"
        }
      },
      {
        "message": {
          "en_US": "Oh hey again, Lea!"
        },
        "autoContinue": false,
        "type": "SHOW_MSG",
        "person": {
          "person": "guests.kit",
          "expression": "DEFAULT"
        }
      },
      {
        "0": [
          {
            "person": {
              "person": "guests.kit",
              "expression": "DEFAULT"
            },
            "message": {
              "en_US": "Want me to join as a \\c[3]fourth\\c[0] party member? There are certain...\\!methods\\! to do that."
            },
            "type": "SHOW_MSG"
          }
        ],
        "1": [
          {
            "person": {
              "person": "guests.kit",
              "expression": "DEFAULT"
            },
            "message": {
              "en_US": "Haha, your party size is glitching the GUI. I should join to make it even bigger!"
            },
            "type": "SHOW_MSG"
          }
        ],
        "2": [
          {
            "person": {
              "person": "guests.kit",
              "expression": "DEFAULT"
            },
            "message": {
              "en_US": "Oh boy! Do you want to form a party again?"
            },
            "type": "SHOW_MSG"
          }
        ],
        "type": "SELECT_FIRST",
        "options": [
          "party.size == 3",
          "party.size > 3",
          "party.size < 3"
        ]
      },
      {
        "0": [
          {
            "message": {
              "en_US": "[nods]"
            },
            "autoContinue": false,
            "type": "SHOW_MSG",
            "person": {
              "person": "main.lea",
              "expression": "NOD"
            }
          },
          {
            "person": {
              "person": "guests.kit",
              "expression": "DEFAULT"
            },
            "message": {
              "en_US": "On my way!"
            },
            "type": "SHOW_MSG"
          },
          {
            "type": "ADD_PARTY_MEMBER",
            "member": "Kit",
            "skipEffect": false,
            "temporary": false
          }
        ],
        "1": [
          {
            "message": {
              "en_US": "[shakes head]"
            },
            "autoContinue": false,
            "type": "SHOW_MSG",
            "person": {
              "person": "main.lea",
              "expression": "SHAKE"
            }
          },
          {
            "person": {
              "person": "guests.kit",
              "expression": "DEFAULT"
            },
            "message": {
              "en_US": "Ok, keep an eye out for cool glitches though!"
            },
            "type": "SHOW_MSG"
          }
        ],
        "type": "SHOW_CHOICE",
        "person": {
          "person": "main.lea",
          "expression": "DEFAULT"
        },
        "options": [
          {
            "0": " ",
            "label": {
              "en_US": "[yes]"
            }
          },
          {
            "1": " ",
            "label": {
              "en_US": "[no]"
            }
          }
        ]
      },
      {
        "name": "end",
        "type": "LABEL"
      },
      {
        "skipSounds": false,
        "type": "END_PRIVATE_MSG"
      }
    ],
    "loopCount": 1,
    "type": {
      "member": "Kit",
      "actionType": "CONTACT",
      "type": "SOCIAL_ACTION"
    }
  },
